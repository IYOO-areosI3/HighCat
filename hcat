# ─────────── Linter rules ───────────
def get_linter_rules(lang: str) -> list[tuple[re.Pattern, str, str]]:
    """Return (regex, message, fix_suggestion) for the given language."""
    rules = [
        (re.compile(r'\t'), "Tab character used – use spaces for indentation.", "Replace tabs with spaces."),
        (re.compile(r' +$'), "Trailing whitespace.", "Remove spaces at end of line."),
        (re.compile(r'.{120,}'), "Line too long (> 120 characters).", "Break into multiple lines."),
        (re.compile(r'[^=!<>]=[^=]'), "Possible assignment '=' instead of comparison '=='?", "Use '==' for comparison."),
    ]

    lang_rules = {
        "py": [
            (re.compile(r'\bexcept\b\s*:'), "Bare 'except:' – catches too much.", "Specify exception type (e.g., except ValueError)."),
            (re.compile(r'\b[a-z]+[A-Z]\w*'), "camelCase variable name – prefer snake_case.", "Use snake_case naming."),
            (re.compile(r'print\s*$'), "Possible leftover print() statement.", "Remove or replace with logging."),
        ],
        "cpp": [
            (re.compile(r'\busing namespace std;'), "using namespace std in global scope is discouraged.", "Move inside function or use std:: prefix."),
            (re.compile(r'\bNULL\b'), "NULL used – prefer nullptr in C++11+.", "Use nullptr."),
        ],
        "c": [
            (re.compile(r'\bNULL\b'), "NULL used – consider nullptr in C23 or use (void*)0.", "Use nullptr or explicit cast."),
        ],
        "js": [
            (re.compile(r'\bvar\b'), "'var' – prefer 'let' or 'const'.", "Use 'let' or 'const'."),
            (re.compile(r'(?<!\\);$'), "Missing semicolon?", "Add semicolon at end of statement."),
            (re.compile(r'console\.(log|warn|error)\s*\('), "console.log left in production?", "Remove or use a logging library."),
        ],
        "java": [
            (re.compile(r'System\.(out|err)\.print'), "System.out/err.print – consider using a logger.", "Use java.util.logging."),
        ],
        "css": [
            (re.compile(r'([a-z-]+)\s*:\s*[^;]*\1\s*:'), "Duplicate property detected.", "Remove duplicate property."),
            (re.compile(r'!important'), "!important used – avoid if possible.", "Use more specific selectors instead."),
        ],
    }
    lang_rules = lang_rules.get(lang, [])
    # Filter out None messages
    lang_rules = [(pat, msg, fix) for pat, msg, fix in lang_rules if msg is not None]
    return rules + lang_rules


def lint_code(text: str, lang: str) -> tuple[list[dict], dict]:
    lines = text.splitlines()
    rules = get_linter_rules(lang)
    issues = []
    bad_lines = set()

    for i, line in enumerate(lines, 1):
        for pattern, msg, fix in rules:
            if pattern.search(line):
                issues.append({"line": i, "message": msg, "fix": fix})
                bad_lines.add(i)
        # Operator spacing check (simple)
        if re.search(r'[a-zA-Z0-9_][+\-*/][a-zA-Z0-9_]', line) \
           and '"' not in line and "'" not in line:
            issues.append({"line": i, "message": "Missing whitespace around operator.", "fix": "Add spaces around operators."})
            bad_lines.add(i)
    return issues, {"bad_lines": bad_lines, "total_lines": len(lines)}


# ─────────── Helpers for highlighting ───────────
def in_ranges(pos: int, ranges: list[tuple[int, int]]) -> bool:
    return any(start <= pos < end for start, end in ranges)


def build(text: str, lang: str) -> list[tuple[int, int, str]]:
    """Return a list of (start, end, style) for colourising `text`."""
    rules = LANG.get(lang)
    if not rules:
        return []

    matches: list[tuple[int, int, str]] = []
    blocked: list[tuple[int, int]] = []

    # 1. Strings
    string_style = scope_style("string")
    for pat in rules["str"]:
        for m in pat.finditer(text):
            blocked.append((m.start(), m.end()))
            matches.append((m.start(), m.end(), string_style))

    # 2. Comments
    comment_style = scope_style("comment")
    for pat in rules["com"]:
        for m in pat.finditer(text):
            blocked.append((m.start(), m.end()))
            matches.append((m.start(), m.end(), comment_style))

    # 3. Keywords (skip overridden ones)
    skip_kw = {w for w, cfg in CUSTOM_WORDS.items() if cfg.get("overwrite", False)}
    for category, words in rules["kw"].items():
        color = COLOR_MAP.get(category, "#00d4ff")
        for kw in words:
            if kw in skip_kw:
                continue
            pat = re.compile(rf"\b{re.escape(kw)}\b")
            for m in pat.finditer(text):
                if not in_ranges(m.start(), blocked):
                    matches.append((m.start(), m.end(), color))

    # 4. Numbers
    num_style = scope_style("number")
    num_pat = rules.get("num", re.compile(r"\b\d+(\.\d+)?\b"))
    for m in num_pat.finditer(text):
        if not in_ranges(m.start(), blocked):
            matches.append((m.start(), m.end(), num_style))

    # 5. Function calls
    func_style = scope_style("function")
    all_keywords = set(chain.from_iterable(rules["kw"].values()))
    func_pat = re.compile(r"\b([a-zA-Z_]\w*)\s*\(")
    for m in func_pat.finditer(text):
        name = m.group(1)
        start = m.start(1)
        if in_ranges(start, blocked) or name in all_keywords:
            continue
        matches.append((start, m.end(1), func_style))

    # 6. JavaScript regex literals (treated as strings)
    if lang == "js" and "regex_lit" in rules:
        lit_pat = rules["regex_lit"]
        for m in lit_pat.finditer(text):
            if not in_ranges(m.start(), blocked):
                matches.append((m.start(), m.end(), string_style))

    # 7. Custom scopes (user-defined patterns with $any)
    for pat, style in CUSTOM_SCOPES:
        for m in pat.finditer(text):
            if not in_ranges(m.start(), blocked):
                matches.append((m.start(), m.end(), style))

    # 8. Custom words
    for word, cfg in CUSTOM_WORDS.items():
        style = cfg["style"]
        if any(not c.isalnum() and c != '_' for c in word):
            pat = re.compile(r"(?<!\w)" + re.escape(word) + r"(?!\w)")
        else:
            pat = re.compile(r"\b" + re.escape(word) + r"\b")
        for m in pat.finditer(text):
            if not in_ranges(m.start(), blocked):
                matches.append((m.start(), m.end(), style))

    return matches


def apply(text: str, matches: list[tuple[int, int, str]]) -> Text:
    t = Text(text)
    for s, e, c in sorted(matches, key=lambda x: x[0], reverse=True):
        t.stylize(c, s, e)
    return t


# ─────────── CLI parsing ───────────
def main() -> None:
    args = sys.argv[1:]
    remaining = []
    custom_words_added = False
    address_errors = False
    i = 0
    while i < len(args):
        arg = args[i]
        if arg == "-address-error":
            address_errors = True
            i += 1
        elif arg == "-config":
            if i + 1 >= len(args):
                console.print("[#ff4b4b]Error: -config requires a file path[/#ff4b4b]")
                sys.exit(1)
            config_path = args[i + 1]
            load_config(config_path)
            custom_words_added = True
            i += 2
        elif arg == "-self-insert":
            if i + 1 >= len(args):
                console.print("[#ff4b4b]Error: -self-insert requires a word[/#ff4b4b]")
                sys.exit(1)
            word = args[i + 1]
            i += 2
            color = None
            underline = False
            overwrite = False   # 🔧 FIX: initialised here
            while i < len(args) and args[i] in ("-color", "-color-hex", "-color-rgb", "-underline", "-overwrite"):
                opt = args[i]
                if opt == "-color":
                    if i + 1 >= len(args):
                        console.print("[#ff4b4b]Error: -color requires a value[/#ff4b4b]")
                        sys.exit(1)
                    color = args[i + 1]
                    i += 2
                elif opt == "-color-hex":
                    if i + 1 >= len(args):
                        console.print("[#ff4b4b]Error: -color-hex requires a value[/#ff4b4b]")
                        sys.exit(1)
                    hex_val = args[i + 1]
                    if not hex_val.startswith("#"):
                        hex_val = "#" + hex_val
                    color = hex_val
                    i += 2
                elif opt == "-color-rgb":
                    if i + 1 >= len(args):
                        console.print("[#ff4b4b]Error: -color-rgb requires a value[/#ff4b4b]")
                        sys.exit(1)
                    rgb_val = args[i + 1].strip()
                    color = f"rgb({rgb_val})"
                    i += 2
                elif opt == "-underline":
                    if i + 1 < len(args) and not args[i + 1].startswith("-"):
                        val = args[i + 1]
                        if val.lower() == "true":
                            underline = True
                        elif val.lower() == "false":
                            underline = False
                        else:
                            console.print("[#ff4b4b]Error: -underline expects 'true' or 'false'[/#ff4b4b]")
                            sys.exit(1)
                        i += 2
                    else:
                        underline = True
                        i += 1
                elif opt == "-overwrite":
                    if i + 1 < len(args) and not args[i + 1].startswith("-"):
                        val = args[i + 1]
                        if val.lower() == "true":
                            overwrite = True
                        elif val.lower() == "false":
                            overwrite = False
                        else:
                            console.print("[#ff4b4b]Error: -overwrite expects 'true' or 'false'[/#ff4b4b]")
                            sys.exit(1)
                        i += 2
                    else:
                        overwrite = True
                        i += 1
            if color is None:
                color = "#ff4b4b"
            addhighlight(word, color, underline, overwrite)   # 🔧 FIX: now passing overwrite
            custom_words_added = True
        else:
            remaining.append(arg)
            i += 1

    if not custom_words_added:
        addhighlight("print", "#ff4b4b")

    if len(remaining) < 1:
        console.print("[#ff4b4b]Usage: hcat [-config <file>] [-address-error] [-self-insert ...] (ext) filename[/#ff4b4b]")
        sys.exit(1)

    if len(remaining) == 2:
        ext, name = remaining[0], remaining[1]
        file = f"{name}.{ext}"
        lang = ext
    else:
        file = remaining[0]
        lang = file.rsplit(".", 1)[-1] if "." in file else None

    try:
        with open(file, "r", encoding="utf-8") as f:
            content = f.read()
    except OSError as err:
        console.print(f"[#ff4b4b]File error: {err}[/#ff4b4b]")
        sys.exit(1)

    if address_errors:
        issues, summary = lint_code(content, lang)
        bad_count = len(summary["bad_lines"])
        good_count = summary["total_lines"] - bad_count
        console.print(Panel(f"[bold]Code Quality Report – {file}[/bold]\n"
                            f"Language: {lang or 'unknown'}",
                            style="#ffffff"))
        if issues:
            table = Table(title="Issues Found", show_header=True, header_style="bold yellow")
            table.add_column("Line", style="#ff4b4b", width=6)
            table.add_column("Issue", style="#ffa500")
            table.add_column("How to fix", style="#00ff7f")
            for issue in issues:
                table.add_row(str(issue["line"]), issue["message"], issue["fix"])
            console.print(table)
        else:
            console.print("[green]No issues found![/green]")
        console.print(f"\nbad  : {bad_count} line(s) with issues\n"
                      f"good : {good_count} clean line(s)")
        return

    matches = build(content, lang)
    styled = apply(content, matches)
    console.print(styled)


if __name__ == "__main__":
    main()