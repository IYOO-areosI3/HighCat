# ─────────── Custom word highlights ───────────
CUSTOM_WORDS: dict[str, dict[str, object]] = {}   # word → {"style": str, "overwrite": bool}

def addhighlight(word: str, color: str, underline: bool = False, overwrite: bool = False) -> None:
    """Register a custom word with a colour, optional underline, and overwrite flag."""
    try:
        Color.parse(color)
    except ValueError:
        console.print(f"[#ff4b4b]Invalid colour value: {color!r}[/#ff4b4b]")
        sys.exit(1)
    style = color
    if underline:
        style += " underline"
    CUSTOM_WORDS[word] = {"style": style, "overwrite": overwrite}


# ─────────── Scope style overrides ───────────
SCOPE_STYLES = {
    "string": {"color": "#ce9178", "underline": False},
    "comment": {"color": "#6a9955", "underline": False},
    "number": {"color": "#b5cea8", "underline": False},
    "function": {"color": "#dcdcaa", "underline": True},
}

def scope_style(scope_name: str) -> str:
    """Return a Rich style string for the given scope, using overrides if set."""
    cfg = SCOPE_STYLES.get(scope_name)
    if not cfg:
        return ""
    style = cfg["color"]
    if cfg["underline"]:
        style += " underline"
    return style


# ─────────── Custom scopes (user patterns with $any) ───────────
CUSTOM_SCOPES: list[tuple[re.Pattern, str]] = []

def compile_custom_scope(pattern_str: str) -> re.Pattern:
    """
    Replace '$any' with a lazy wildcard (.*?) and escape the rest.
    Returns a compiled regex.
    """
    parts = pattern_str.split("$any")
    escaped_parts = [re.escape(part) for part in parts]
    regex = ".*?".join(escaped_parts)
    return re.compile(regex)


# ─────────── Load config TOML ───────────
def load_config(filepath: str) -> None:
    """Parse a TOML config file and register all enabled custom words, scopes, and custom scopes."""
    if tomllib is None:
        console.print("[#ff4b4b]Error: TOML support requires tomli/tomllib. Install tomli with 'pip install tomli'[/#ff4b4b]")
        sys.exit(1)

    try:
        with open(filepath, "rb") as f:
            config = tomllib.load(f)
    except FileNotFoundError:
        console.print(f"[#ff4b4b]Config file not found: {filepath}[/#ff4b4b]")
        sys.exit(1)
    except tomllib.TOMLDecodeError as e:
        console.print(f"[#ff4b4b]Invalid TOML in {filepath}: {e}[/#ff4b4b]")
        sys.exit(1)

    # Validate [id] section
    id_section = config.get("id", {})
    if not id_section.get("config"):
        console.print(f"[#ff4b4b]Missing or false '[id] config = true' in {filepath}[/#ff4b4b]")
        sys.exit(1)

    # ── Custom keywords ──
    keywords = config.get("config_keyword", {})
    if isinstance(keywords, dict):
        for word, word_cfg in keywords.items():
            if not isinstance(word_cfg, dict):
                continue
            enabled = word_cfg.get("enabled", False)
            if not enabled:
                continue
            color = str(word_cfg.get("color", "#ff4b4b"))
            underline = word_cfg.get("underline", False)
            overwrite = word_cfg.get("overwrite", False)
            addhighlight(word, color, underline, overwrite)

    # ── Scope overrides ──
    scopes = config.get("config_scope", {})
    if isinstance(scopes, dict):
        for scope_name, scope_cfg in scopes.items():
            if scope_name not in SCOPE_STYLES:
                console.print(f"[yellow]Warning: Unknown scope '{scope_name}' in config – ignored[/yellow]")
                continue
            if isinstance(scope_cfg, dict):
                if "color" in scope_cfg:
                    SCOPE_STYLES[scope_name]["color"] = str(scope_cfg["color"])
                if "underline" in scope_cfg:
                    SCOPE_STYLES[scope_name]["underline"] = bool(scope_cfg["underline"])

    # ── Custom scopes (user‑defined patterns with $any) ──
    custom_scopes = config.get("config_customScope", {})
    if isinstance(custom_scopes, dict):
        for pattern_str, scope_cfg in custom_scopes.items():
            if not isinstance(scope_cfg, dict):
                continue
            color = str(scope_cfg.get("color", "#c586c0"))
            underline = bool(scope_cfg.get("underline", False))
            style = color
            if underline:
                style += " underline"
            try:
                compiled = compile_custom_scope(pattern_str)
                CUSTOM_SCOPES.append((compiled, style))
            except re.error as e:
                console.print(f"[yellow]Warning: Invalid custom scope pattern '{pattern_str}' – {e}[/yellow]")


